{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@kadaster/ggc-map": [
        "projects/ggc-map/src/public-api.ts"
      ],
      "@kadaster/ggc-models": [
        "projects/ggc-models/src/public-api.ts"
      ],
      "@kadaster/ggc-search-location": [
        "projects/ggc-search-location/src/public-api.ts"
      ]
    }
  },
  "include": ["projects/**/*.ts"],
  "exclude": [
    "**/*.spec.ts",
    "**/*.d.ts",
    "projects/library-app/**/*",
    "src/**/*",
    "dist/**/*",
    "out-tsc/**/*",
    "node_modules/**/*"
  ]
}
