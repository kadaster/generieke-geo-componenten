{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@kadaster/ggc-dataset-tree": [
        "projects/ggc-dataset-tree/src/public-api.ts"
      ],
      "@kadaster/ggc-legend": ["projects/ggc-legend/src/public-api.ts"],
      "@kadaster/ggc-map": ["projects/ggc-map/src/public-api.ts"],
      "@kadaster/ggc-models": ["projects/ggc-models/src/public-api.ts"],
      "@kadaster/ggc-search-location": [
        "projects/ggc-search-location/src/public-api.ts"
      ],
      "@kadaster/ggc-toolbar": ["projects/ggc-toolbar/src/public-api.ts"]
    }
  },
  "include": ["projects/**/*.ts"],
  "exclude": [
    "**/*.spec.ts",
    "**/*.d.ts",
    "projects/ggc-home/**/*",
    "src/**/*",
    "dist/**/*",
    "out-tsc/**/*",
    "node_modules/**/*"
  ]
}
