{
  "name": "ggc-library",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "test": "ng test",
    "test:ggc-cesium": "ng test --project ggc-cesium",
    "test:ggc-dataset-tree": "ng test --project ggc-dataset-tree",
    "test:ggc-feature-info": "ng test --project ggc-feature-info",
    "test:ggc-home": "ng test --project ggc-home",
    "test:ggc-legend": "ng test --project ggc-legend",
    "test:ggc-map": "ng test --project ggc-map",
    "test:ggc-search-location": "ng test --project ggc-search-location",
    "test:ggc-toolbar": "ng test --project ggc-toolbar",
    "test:cov:ggc-cesium": "ng test --project ggc-cesium --code-coverage --watch=false --browsers=ChromeHeadlessNoSandbox --source-map=true",
    "test:cov:ggc-dataset-tree": "ng test --project ggc-dataset-tree --code-coverage --watch=false --browsers=ChromeHeadlessNoSandbox --source-map=true",
    "test:cov:ggc-feature-info": "ng test --project ggc-feature-info --code-coverage --watch=false --browsers=ChromeHeadlessNoSandbox --source-map=true",
