    "lint:ggc-cesium": "ng lint --project ggc-cesium",
    "lint:ggc-dataset-tree": "ng lint --project ggc-dataset-tree",
    "lint:ggc-feature-info": "ng lint --project ggc-feature-info",
    "lint:ggc-home": "ng lint --project ggc-home",
    "lint:ggc-legend": "ng lint --project ggc-legend",
    "lint:ggc-map": "ng lint --project ggc-map",
    "lint:ggc-models": "ng lint --project ggc-models",
    "lint:ggc-search-location": "ng lint --project ggc-search-location",
    "lint:ggc-toolbar": "ng lint --project ggc-toolbar",
    "lint:all": "npm run lint:ggc-cesium && npm run lint:ggc-dataset-tree && npm run lint:ggc-home && npm run lint:ggc-legend && npm run lint:ggc-map && npm run lint:ggc-models && npm run lint:ggc-search-location && npm run lint:ggc-toolbar",
    "lint:fix:ggc-cesium": "ng lint --project ggc-cesium --fix",
    "lint:fix:ggc-dataset-tree": "ng lint --project ggc-dataset-tree --fix",
    "lint:fix:ggc-feature-info": "ng lint --project ggc-feature-info --fix",
    "lint:fix:ggc-home": "ng lint --project ggc-home --fix",
    "lint:fix:ggc-legend": "ng lint --project ggc-legend --fix",
    "lint:fix:ggc-map": "ng lint --project ggc-map --fix",
    "lint:fix:ggc-models": "ng lint --project ggc-models --fix",
    "lint:fix:ggc-search-location": "ng lint --project ggc-search-location --fix",
    "lint:fix:ggc-toolbar": "ng lint --project ggc-toolbar --fix",
    "lint:fix:all": "npm run lint:fix:ggc-cesium && npm run lint:fix:ggc-dataset-tree && npm run lint:fix:ggc-feature-info && npm run lint:fix:ggc-legend && npm run lint:fix:ggc-map && npm run lint:fix:ggc-models && npm run lint:fix:ggc-search-location && npm run lint:fix:ggc-toolbar",
    "build:ggc-cesium": "ng build --project ggc-cesium --configuration production",
    "build:ggc-dataset-tree": "ng build --project ggc-dataset-tree --configuration production",
    "build:ggc-feature-info": "ng build --project ggc-feature-info --configuration production",
    "build:ggc-legend": "ng build --project ggc-legend --configuration production",
    "build:ggc-map": "ng build --project ggc-map --configuration production",
    "build:ggc-models": "ng build --project ggc-models --configuration production",
    "build:ggc-search-location": "ng build --project ggc-search-location --configuration production",
    "build:ggc-toolbar": "ng build --project ggc-toolbar --configuration production",
    "build:all": "npm run build:ggc-models && npm run build:ggc-cesium && npm run build:ggc-dataset-tree && npm run build:ggc-feature-info && npm run build:ggc-legend && npm run build:ggc-map && npm run build:ggc-search-location && npm run build:ggc-toolbar",
    "check:ggc-cesium": "npm run lint:ggc-cesium && npm run test:cov:ggc-cesium && npm run build:ggc-cesium",
    "check:ggc-dataset-tree": "npm run lint:ggc-dataset-tree && npm run test:cov:ggc-dataset-tree && npm run build:ggc-dataset-tree",
    "check:ggc-feature-info": "npm run lint:ggc-feature-info && npm run test:cov:ggc-feature-info && npm run build:ggc-feature-info",
    "check:ggc-home": "npm run lint:ggc-home",
    "check:ggc-legend": "npm run lint:ggc-legend && npm run test:cov:ggc-legend && npm run build:ggc-legend",
    "check:ggc-map": "npm run lint:ggc-map && npm run test:cov:ggc-map && npm run build:ggc-map",
    "check:ggc-models": "npm run lint:ggc-models && npm run test:cov:ggc-models && npm run build:ggc-models",
    "check:ggc-search-location": "npm run lint:ggc-search-location && npm run test:cov:ggc-search-location && npm run build:ggc-search-location",
    "check:ggc-toolbar": "npm run lint:ggc-toolbar && npm run test:cov:ggc-toolbar && npm run build:ggc-toolbar",
    "check:all": "npm run check:ggc-models && npm run check:ggc-cesium && npm run check:ggc-dataset-tree && npm run check:ggc-feature-info && npm run check:ggc-legend && npm run check:ggc-map && npm run check:ggc-search-location && npm run check:ggc-toolbar",
    "version": "npm run build:all",
    "tsdocs:generate": "typedoc --options typedoc.json"
  },
