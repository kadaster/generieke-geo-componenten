{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "ggc-cesium": {
      "projectType": "library",
      "root": "projects/ggc-cesium",
      "sourceRoot": "projects/ggc-cesium/src",
      "prefix": "ggc",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "tsConfig": "projects/ggc-cesium/tsconfig.lib.json",
            "project": "projects/ggc-cesium/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/ggc-cesium/tsconfig.lib.prod.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "projects/ggc-cesium/src/test.ts",
            "tsConfig": "projects/ggc-cesium/tsconfig.spec.json",
            "karmaConfig": "projects/ggc-cesium/karma.conf.js"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/ggc-cesium/**/*.ts",
              "projects/ggc-cesium/**/*.html"
            ]
          }
        }
      }
    },
