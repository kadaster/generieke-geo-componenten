            ]
          }
        }
      }
    },
    "ggc-home": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/ggc-home",
      "sourceRoot": "projects/ggc-home/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/ggc-home/src/main.ts",
            "tsConfig": "projects/ggc-home/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/ggc-home/public"
              },
              {
                "glob": "**/*",
                "input": "projects/ggc-home/src/app",
                "output": "/code/"
              }
            ],
            "sourceMap": {
              "styles": true,
              "scripts": true,
              "vendor": true
            },
            "styles": [
              "projects/ggc-home/src/styles.scss",
              "node_modules/ol/ol.css",
              "@cesium/widgets/Source/widgets.css"
            ],
            "scripts": [
              "./node_modules/jquery/dist/jquery.min.js",
              "./node_modules/popper.js/dist/umd/popper.min.js",
              "./node_modules/bootstrap/dist/js/bootstrap.min.js"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2MB",
                  "maximumError": "3MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "ggc-home:build:production"
            },
            "development": {
              "buildTarget": "ggc-home:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/ggc-home/**/*.ts",
              "projects/ggc-home/**/*.html"
            ]
          }
        }
      }
    },
